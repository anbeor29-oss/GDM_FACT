# ================================================================
# ERP CFDI 4.0 - ENVIRONMENT CONFIGURATION
# ================================================================
# Copy this file to .env and fill in the actual values
# NEVER commit .env with real values to version control
# ================================================================

# ================================================================
# APPLICATION
# ================================================================
NODE_ENV=development
APP_NAME="ERP CFDI Mexico"
APP_PORT=3001
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001
API_VERSION=v1

# ================================================================
# DATABASE
# ================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cfdi_erp
DB_USER=app_user
DB_PASSWORD=change_me_in_production
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# ================================================================
# REDIS (for sessions, caching, queues)
# ================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ================================================================
# JWT & SECURITY
# ================================================================
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_this
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# Encryption for sensitive data (passwords, certificates)
ENCRYPTION_KEY=your_encryption_key_32_chars_long_here

# ================================================================
# CLOUD STORAGE (AWS S3 or Azure Blob)
# ================================================================
# AWS S3
STORAGE_TYPE=s3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=cfdi-erp-storage
AWS_S3_FOLDER_PREFIX=invoices

# Alternative: Azure Blob Storage
# STORAGE_TYPE=azure
# AZURE_STORAGE_ACCOUNT_NAME=youraccountname
# AZURE_STORAGE_ACCOUNT_KEY=your_account_key
# AZURE_CONTAINER_NAME=cfdi-storage

# ================================================================
# EMAIL SERVICE (SendGrid or AWS SES)
# ================================================================
EMAIL_SERVICE=sendgrid
SENDGRID_API_KEY=your_sendgrid_api_key

# Alternative: AWS SES
# EMAIL_SERVICE=ses
# AWS_SES_REGION=us-east-1

EMAIL_FROM=noreply@tuempresa.com
EMAIL_FROM_NAME="ERP Facturación CFDI"

# ================================================================
# SMS NOTIFICATIONS (Twilio)
# ================================================================
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ================================================================
# PAC CONFIGURATION (Phase 2)
# ================================================================
# Default PAC to use
DEFAULT_PAC=finkok

# Finkok
FINKOK_USERNAME=your_finkok_username
FINKOK_PASSWORD=your_finkok_password
FINKOK_ENVIRONMENT=production
# FINKOK_ENVIRONMENT=demo (for testing)

# Facturama
FACTURAMA_API_KEY=your_facturama_api_key
FACTURAMA_ENVIRONMENT=production

# SW Sapien
SWSAPIEN_ENVIRONMENT=PRODUCCIÓN
SWSAPIEN_URL_WSOCKET=wss://facturacion.swsapien.com

# ================================================================
# SAT CATALOGS
# ================================================================
# URL to download SAT catalogs (if using custom source)
SAT_CATALOGS_URL=https://www.sat.gob.mx/

# Update catalogs every (in days)
SAT_CATALOGS_UPDATE_INTERVAL=30

# ================================================================
# LOGGING
# ================================================================
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE_PATH=./logs
LOG_FILE_NAME=app.log
LOG_MAX_FILE_SIZE=10485760

# ================================================================
# MONITORING & OBSERVABILITY
# ================================================================
# Optional: DataDog, New Relic, Sentry
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
DATADOG_API_KEY=
NEW_RELIC_LICENSE_KEY=

# ================================================================
# CORS & SECURITY
# ================================================================
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ================================================================
# FRONTEND CONFIGURATION
# ================================================================
REACT_APP_API_URL=http://localhost:3001
REACT_APP_ENVIRONMENT=development
REACT_APP_VERSION=0.1.0

# ================================================================
# DEVELOPMENT
# ================================================================
DEBUG=app:*
MOCK_PAC=true
MOCK_EMAIL=false

# ================================================================
# FEATURE FLAGS
# ================================================================
FEATURE_PAC_INTEGRATION=false
FEATURE_MULTI_RFC=true
FEATURE_INVENTORY=false
FEATURE_ADVANCED_REPORTS=false

