{
  "name": "cfdi-erp-backend",
  "version": "0.1.0",
  "description": "Backend para ERP CFDI 4.0 México",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node -r dotenv/config src/index.ts",
    "build": "./node_modules/.bin/tsc && node scripts/copy-assets.js",
    "start": "node dist/index.js",
    "start:prod": "npm run migrate:up && node dist/index.js",
    "migrate:up": "node scripts/migrate-up.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "migrate": "ts-node -r dotenv/config scripts/migrate.ts",
    "seed:catalogs": "ts-node -r dotenv/config scripts/seed-catalogs.ts",
    "seed:demo": "ts-node -r dotenv/config scripts/seed-demo.ts",
    "seed:customers": "ts-node -r dotenv/config scripts/seed-customers.ts",
    "seed:products": "ts-node -r dotenv/config scripts/seed-products.ts",
    "seed:invoices": "ts-node -r dotenv/config scripts/seed-invoices.ts",
    "seed:cfdi": "ts-node -r dotenv/config scripts/seed-cfdi.ts",
    "create:admin": "ts-node -r dotenv/config scripts/create-admin.ts"
  },
  "keywords": [
    "cfdi",
    "facturación",
    "sat",
    "mexico",
    "erp"
  ],
  "author": "anbeor29@gmail.com",
  "license": "PRIVATE",
  "dependencies": {
    "archiver": "^7.0.1",
    "axios": "^1.6.5",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pdf-parse": "^1.1.4",
    "pdfkit": "^0.13.0",
    "pg": "^8.11.3",
    "redis": "^4.6.11",
    "sharp": "^0.35.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.10.6",
    "@types/pdf-parse": "^1.1.5",
    "@types/pdfkit": "^0.12.9",
    "@types/pg": "^8.11.4",
    "@types/uuid": "^9.0.8",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^6.16.0",
    "@typescript-eslint/parser": "^6.16.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": "20.x",
    "npm": ">=9.0.0"
  }
}
