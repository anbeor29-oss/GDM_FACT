# ================================================================
# BACKEND - ENVIRONMENT CONFIGURATION
# ================================================================
# Copy to .env and fill with your values

# Application
NODE_ENV=development
APP_NAME=ERP CFDI Mexico Backend
APP_PORT=3001
API_VERSION=v1
LOG_LEVEL=debug

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cfdi_erp
DB_USER=app_user
DB_PASSWORD=postgres_password
DB_SSL=false
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# JWT & Security
JWT_SECRET=your_jwt_secret_key_change_this_in_production_min_32_chars
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_change_this_min_32_chars
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=7d

# Encryption
ENCRYPTION_KEY=your_encryption_key_32_chars_long_here_12345678

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Cloud Storage (AWS S3 or Azure)
STORAGE_TYPE=s3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=cfdi-erp-storage
AWS_S3_FOLDER_PREFIX=invoices

# Email Service
EMAIL_SERVICE=sendgrid
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM=noreply@tuempresa.com
EMAIL_FROM_NAME=ERP Facturación CFDI

# Feature Flags
FEATURE_PAC_INTEGRATION=false
FEATURE_MULTI_RFC=true
FEATURE_INVENTORY=false
FEATURE_ADVANCED_REPORTS=false

# Development
DEBUG=app:*
MOCK_PAC=true
MOCK_EMAIL=false

# ================================================================
# PAC — Proveedor de timbrado
# ================================================================
# PAC_PROVIDER: MOCK (default, para dev) | SW_SAPIEN (real, en prod)
# El token se genera en https://swpanel.mx → Configuración → Tokens.
# Es un JWT largo (~500+ chars). NUNCA subir a git. Rotable desde el panel.
PAC_PROVIDER=MOCK
SW_SAPIEN_ENV=sandbox
SW_SAPIEN_TOKEN=

# Frontend URL
FRONTEND_URL=http://localhost:3000
